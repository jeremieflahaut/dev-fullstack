---
const year = new Date().getFullYear();
---

<footer class="border-t border-line">
  <div
    class="mx-auto flex w-full max-w-5xl flex-col gap-3 px-4 py-8 font-mono text-xs text-muted sm:flex-row sm:items-center sm:justify-between sm:px-6"
  >
    <p>© {year} Jérémie Flahaut · dev-fullstack.net</p>
    <p class="flex flex-wrap items-center gap-x-4 gap-y-1">
      <a class="transition-colors hover:text-accent" href="https://github.com/jeremieflahaut" rel="me">github</a>
      <a class="transition-colors hover:text-accent" href="/rss.xml">rss</a>
      <span aria-hidden="true">·</span>
      <span>
        construit avec <a
          class="underline decoration-line underline-offset-2 transition-colors hover:text-accent"
          href="https://astro.build">astro</a
        >, déployé sur github pages
      </span>
    </p>
  </div>
</footer>
