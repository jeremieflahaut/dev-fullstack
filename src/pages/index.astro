---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getPublishedPosts } from '../lib/posts';

const latestPosts = (await getPublishedPosts()).slice(0, 3);

const stack = [
  'Laravel',
  'PHP',
  'Vue / Nuxt',
  'TypeScript',
  'Tailwind CSS',
  'Docker',
  'MySQL',
  'GitHub Actions',
];
---

<BaseLayout
  title="Jérémie Flahaut — développeur web fullstack"
  description="Site perso et blog de Jérémie Flahaut, développeur web fullstack (Laravel, Vue, Docker). Notes, retours d'expérience et bouts de code, en français."
>
  <!-- ——— Héros ——— -->
  <section class="relative overflow-hidden">
    <div
      class="bg-grid absolute inset-0 [mask-image:radial-gradient(ellipse_70%_60%_at_50%_0%,black_30%,transparent_75%)]"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute left-1/2 top-[-12rem] size-[34rem] -translate-x-1/2 rounded-full blur-3xl"
      style="background: var(--glow)"
      aria-hidden="true"
    >
    </div>

    <div
      class="relative mx-auto grid w-full max-w-5xl gap-12 px-4 pb-20 pt-16 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-center lg:pb-28 lg:pt-24"
    >
      <div>
        <p class="reveal font-mono text-sm text-accent" style="--d: 0s">
          // développeur web fullstack
        </p>
        <h1
          class="reveal mt-4 font-display text-5xl font-bold tracking-tight sm:text-6xl lg:text-7xl"
          style="--d: 0.08s"
        >
          Jérémie<br />Flahaut<span class="text-accent">.</span>
        </h1>
        <p
          class="reveal mt-6 max-w-md text-base leading-relaxed text-muted sm:text-lg"
          style="--d: 0.16s"
        >
          J'assemble des applications web solides — <strong class="font-medium text-fg"
            >Laravel</strong
          > côté serveur, <strong class="font-medium text-fg">Vue</strong> côté client,
          <strong class="font-medium text-fg">Docker</strong> partout. Ici, je documente ce que
          j'apprends en chemin.
        </p>
        <div class="reveal mt-8 flex flex-wrap items-center gap-3" style="--d: 0.24s">
          <a
            href="/blog/"
            class="group inline-flex items-center gap-2 border border-line px-4 py-2 font-mono text-sm transition-colors hover:border-accent hover:text-accent"
          >
            <span class="text-accent transition-transform group-hover:translate-x-0.5">❯</span>
            lire le blog
          </a>
          <a
            href="/a-propos/"
            class="inline-flex items-center gap-2 px-2 py-2 font-mono text-sm text-muted transition-colors hover:text-accent"
          >
            à propos →
          </a>
        </div>
      </div>

      <!-- Faux terminal -->
      <div class="reveal" style="--d: 0.2s">
        <div
          class="overflow-hidden rounded-lg border border-line bg-surface shadow-[0_24px_60px_-24px_rgba(0,0,0,0.35)]"
        >
          <div class="flex items-center gap-2 border-b border-line px-4 py-2.5">
            <span class="size-2.5 rounded-full bg-[#ff5f57]"></span>
            <span class="size-2.5 rounded-full bg-[#febc2e]"></span>
            <span class="size-2.5 rounded-full bg-[#28c840]"></span>
            <span class="ml-2 font-mono text-[11px] text-muted">jeremie@dev-fullstack — ~</span>
          </div>
          <div class="space-y-2.5 px-4 py-4 font-mono text-[13px] leading-relaxed">
            <p class="reveal" style="--d: 0.45s"><span class="text-accent">❯</span> whoami</p>
            <p class="reveal text-muted" style="--d: 0.65s">jeremie — dev fullstack laravel</p>
            <p class="reveal" style="--d: 0.9s">
              <span class="text-accent">❯</span> php artisan inspire
            </p>
            <p class="reveal text-muted" style="--d: 1.1s">
              « La simplicité est la sophistication suprême. »
            </p>
            <p class="reveal" style="--d: 1.35s">
              <span class="text-accent">❯</span> docker compose up -d site-perso
            </p>
            <p class="reveal text-muted" style="--d: 1.55s">
              <span class="text-[#28c840]">✔</span> Container dev-fullstack —
              <span class="text-[#28c840]">Started</span>
            </p>
            <p class="reveal" style="--d: 1.8s">
              <span class="text-accent">❯</span>
              <span
                class="cursor-blink inline-block h-[1.1em] w-[0.55em] translate-y-[3px] bg-accent"
              ></span>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ——— Derniers articles ——— -->
  <section class="mx-auto w-full max-w-5xl px-4 pb-20 sm:px-6">
    <div class="mb-2 flex items-end justify-between gap-4">
      <div>
        <p class="font-mono text-xs text-muted">~/blog --latest</p>
        <h2 class="mt-1 font-display text-2xl font-bold tracking-tight sm:text-3xl">
          Derniers articles
        </h2>
      </div>
      <a href="/blog/" class="font-mono text-sm text-muted transition-colors hover:text-accent">
        tout voir →
      </a>
    </div>
    <div>
      {
        latestPosts.map((post) => (
          <PostCard
            href={`/blog/${post.id}/`}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
          />
        ))
      }
    </div>
  </section>

  <!-- ——— Stack ——— -->
  <section class="border-t border-line bg-surface/60">
    <div class="mx-auto w-full max-w-5xl px-4 py-12 sm:px-6">
      <p class="font-mono text-xs text-muted">$ stack --list</p>
      <ul class="mt-4 flex flex-wrap gap-2">
        {
          stack.map((item) => (
            <li class="border border-line px-3 py-1.5 font-mono text-xs text-muted transition-colors hover:border-accent hover:text-accent">
              {item}
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
