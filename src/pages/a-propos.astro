---
import BaseLayout from '../layouts/BaseLayout.astro';

const stackGroups = [
  { label: 'backend', items: ['Laravel', 'PHP 8', 'MySQL', 'MongoDB', 'Redis', 'API REST'] },
  { label: 'frontend', items: ['JavaScript / TypeScript', 'Svelte'] },
  { label: 'infra & outils', items: ['Docker', 'Git', 'GitHub Actions', 'Linux / WSL2'] },
  { label: 'exploration', items: ['Claude Code', 'outillage dev assisté par IA'] },
];
---

<BaseLayout
  title="À propos · dev-fullstack"
  description="Jérémie Flahaut, développeur backend senior Laravel — 8 ans et plus à construire des applications qui durent. Stack, philosophie et side projects."
>
  <article class="mx-auto w-full max-w-3xl px-4 py-16 sm:px-6 lg:py-20">
    <p class="reveal font-mono text-sm text-accent" style="--d: 0s">~/a-propos</p>
    <h1
      class="reveal mt-4 font-display text-4xl font-bold tracking-tight sm:text-5xl"
      style="--d: 0.08s"
    >
      Salut, moi c'est Jérémie<span class="text-accent">.</span>
    </h1>

    <div class="reveal mt-8 space-y-5 leading-relaxed text-muted" style="--d: 0.16s">
      <p>
        <strong class="font-medium text-fg">Développeur backend senior</strong> — plus de 8 ans à
        construire et faire évoluer des applications avec
        <strong class="font-medium text-fg">Laravel</strong> et
        <strong class="font-medium text-fg">PHP</strong>, depuis Antibes.
      </p>
      <p>
        Depuis 2018, je développe une plateforme métier interne&nbsp;: fonctionnalités,
        conception d'APIs, intégrations tierces, optimisation des performances et du modèle de
        données, refactoring, tests et revues de code. Autonome sur tout le back-end, et côté
        front quand un projet le demande — mais mon cœur de métier, c'est le backend.
      </p>
      <p>
        Mon approche est pragmatique&nbsp;: <em class="text-fg">je cherche ce qui marche, pas ce qui
        fait joli sur le papier</em>. Ce qui m'intéresse&nbsp;: les applications qui durent, le code
        qu'on peut reprendre trois ans plus tard sans avoir envie de tout réécrire, et les
        architectures simples qui tiennent la charge.
      </p>
      <p>
        À côté, quand l'envie est là, je passe en mode fullstack sur quelques side projects&nbsp;:
        des petites apps Laravel, des stacks Docker réutilisables, et ce site — statique, généré
        avec Astro, hébergé gratuitement sur GitHub Pages, et construit en pair-programming avec
        Claude Code, dont j'explore l'usage.
      </p>
    </div>

    <section class="reveal mt-12" style="--d: 0.24s">
      <h2 class="font-display text-2xl font-bold tracking-tight">
        La stack<span class="text-accent">.</span>
      </h2>
      <div class="mt-5 space-y-4">
        {
          stackGroups.map((group) => (
            <div class="grid gap-2 sm:grid-cols-[8.5rem_1fr] sm:gap-6">
              <p class="font-mono text-xs leading-7 text-accent">{group.label}</p>
              <ul class="flex flex-wrap gap-2">
                {group.items.map((item) => (
                  <li class="border border-line px-2.5 py-1 font-mono text-xs text-muted">
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>

    <section class="reveal mt-12" style="--d: 0.32s">
      <h2 class="font-display text-2xl font-bold tracking-tight">
        Me trouver<span class="text-accent">.</span>
      </h2>
      <p class="mt-4 leading-relaxed text-muted">
        Sur <a
          href="https://github.com/jeremieflahaut"
          class="font-medium text-fg underline decoration-line underline-offset-4 transition-colors hover:text-accent"
          rel="me">GitHub</a
        > pour le code, sur <a
          href="https://www.linkedin.com/in/jeremie-flahaut-developpeur-fullstack-php-javascript"
          class="font-medium text-fg underline decoration-line underline-offset-4 transition-colors hover:text-accent"
          rel="me">LinkedIn</a
        > pour le reste, ou via le <a
          href="/rss.xml"
          class="font-medium text-fg underline decoration-line underline-offset-4 transition-colors hover:text-accent"
          >flux RSS</a
        > pour suivre les prochains articles.
      </p>
    </section>
  </article>
</BaseLayout>
