---
import type { Page } from 'astro';

interface Props {
  page: Page;
}

const { page } = Astro.props;
---

{
  page.lastPage > 1 && (
    <nav
      class="mt-12 flex items-center justify-between gap-4 border-t border-line pt-6 font-mono text-sm"
      aria-label="Pagination des articles"
    >
      {page.url.prev ? (
        <a
          href={page.url.prev}
          rel="prev"
          class="group inline-flex items-center gap-2 text-muted transition-colors hover:text-accent"
        >
          <span class="inline-block transition-transform group-hover:-translate-x-0.5">←</span>
          précédent
        </a>
      ) : (
        <span class="invisible inline-flex items-center gap-2" aria-hidden="true">
          ← précédent
        </span>
      )}

      <span class="text-muted">
        page {page.currentPage} / {page.lastPage}
      </span>

      {page.url.next ? (
        <a
          href={page.url.next}
          rel="next"
          class="group inline-flex items-center gap-2 text-muted transition-colors hover:text-accent"
        >
          suivant
          <span class="inline-block transition-transform group-hover:translate-x-0.5">→</span>
        </a>
      ) : (
        <span class="invisible inline-flex items-center gap-2" aria-hidden="true">
          suivant →
        </span>
      )}
    </nav>
  )
}
