---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getPublishedPosts } from '../../lib/posts';

const posts = await getPublishedPosts();
---

<BaseLayout
  title="Blog · dev-fullstack"
  description="Articles d'un développeur web fullstack : Laravel, PHP, Vue, Docker — notes pratiques et retours d'expérience, en français."
>
  <section class="mx-auto w-full max-w-3xl px-4 py-16 sm:px-6 lg:py-20">
    <p class="reveal font-mono text-sm text-accent" style="--d: 0s">~/blog</p>
    <h1
      class="reveal mt-4 font-display text-4xl font-bold tracking-tight sm:text-5xl"
      style="--d: 0.08s"
    >
      Le blog<span class="text-accent">.</span>
    </h1>
    <p class="reveal mt-4 max-w-xl leading-relaxed text-muted" style="--d: 0.16s">
      Des notes concrètes sur Laravel, Docker et le développement web — les problèmes que je
      rencontre, et comment je les résous.
    </p>

    <div class="reveal mt-10" style="--d: 0.24s">
      {
        posts.map((post) => (
          <PostCard
            href={`/blog/${post.id}/`}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
