---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getAllTags } from '../../../lib/posts';

const tags = await getAllTags();
---

<BaseLayout
  title="Tags · blog · dev-fullstack"
  description="Parcourir les articles du blog dev-fullstack par thème."
>
  <section class="mx-auto w-full max-w-3xl px-4 py-16 sm:px-6 lg:py-20">
    <p class="reveal font-mono text-sm text-muted" style="--d: 0s">
      <a href="/blog/" class="transition-colors hover:text-accent">~/blog</a>
      <span class="text-accent">❯</span>
      tags
    </p>
    <h1
      class="reveal mt-4 font-display text-4xl font-bold tracking-tight sm:text-5xl"
      style="--d: 0.08s"
    >
      Tags<span class="text-accent">.</span>
    </h1>
    <p class="reveal mt-4 max-w-xl leading-relaxed text-muted" style="--d: 0.16s">
      Parcourir les articles par thème.
    </p>

    <ul class="reveal mt-10 flex flex-wrap gap-3 font-mono text-sm" style="--d: 0.24s">
      {
        tags.map(({ tag, count }) => (
          <li>
            <a
              href={`/blog/tags/${tag}/`}
              class="inline-flex items-center gap-2 border border-line px-3 py-1.5 text-muted transition-colors hover:border-accent hover:text-accent"
            >
              #{tag}
              <span class="text-muted/60">{count}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
