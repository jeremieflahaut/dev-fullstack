---
import BaseLayout from '../layouts/BaseLayout.astro';

const stackGroups = [
  { label: 'backend', items: ['Laravel', 'PHP 8', 'MySQL', 'Redis', 'API REST'] },
  { label: 'frontend', items: ['Vue / Nuxt', 'Inertia', 'TypeScript', 'Tailwind CSS'] },
  { label: 'infra & outils', items: ['Docker', 'GitHub Actions', 'Traefik', 'Linux / WSL2'] },
];
---

<BaseLayout
  title="À propos · dev-fullstack"
  description="Qui est Jérémie Flahaut — développeur web fullstack Laravel : parcours, stack technique et side projects."
>
  <article class="mx-auto w-full max-w-3xl px-4 py-16 sm:px-6 lg:py-20">
    <p class="reveal font-mono text-sm text-accent" style="--d: 0s">~/a-propos</p>
    <h1
      class="reveal mt-4 font-display text-4xl font-bold tracking-tight sm:text-5xl"
      style="--d: 0.08s"
    >
      Salut, moi c'est Jérémie<span class="text-accent">.</span>
    </h1>

    <!-- TODO(jeremie) : relire et personnaliser ce texte — c'est une base à ajuster. -->
    <div class="reveal mt-8 space-y-5 leading-relaxed text-muted" style="--d: 0.16s">
      <p>
        Je suis <strong class="font-medium text-fg">développeur web fullstack</strong>, salarié le
        jour, bidouilleur le soir. Mon terrain de jeu principal :
        <strong class="font-medium text-fg">Laravel</strong> et son écosystème, avec du
        <strong class="font-medium text-fg">Vue</strong> ou de l'<strong
          class="font-medium text-fg">Inertia</strong
        > côté client, et du <strong class="font-medium text-fg">Docker</strong> pour faire tourner
        tout ça proprement.
      </p>
      <p>
        Ce site est mon coin du web : un endroit pour documenter ce que j'apprends, garder une
        trace des problèmes résolus, et partager des retours d'expérience concrets — en français,
        parce que les ressources de qualité dans notre langue ne sont jamais de trop.
      </p>
      <p>
        Côté side projects : un tracker de portefeuille PEA (Laravel + Nuxt + un scraper Python),
        des stacks Docker réutilisables, et ce blog. Tout tourne sur un petit VPS… sauf ce site,
        généré statiquement et hébergé gratuitement sur GitHub Pages.
      </p>
    </div>

    <section class="reveal mt-12" style="--d: 0.24s">
      <h2 class="font-display text-2xl font-bold tracking-tight">
        La stack<span class="text-accent">.</span>
      </h2>
      <div class="mt-5 space-y-4">
        {
          stackGroups.map((group) => (
            <div class="grid gap-2 sm:grid-cols-[8.5rem_1fr] sm:gap-6">
              <p class="font-mono text-xs leading-7 text-accent">{group.label}</p>
              <ul class="flex flex-wrap gap-2">
                {group.items.map((item) => (
                  <li class="border border-line px-2.5 py-1 font-mono text-xs text-muted">
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>

    <section class="reveal mt-12" style="--d: 0.32s">
      <h2 class="font-display text-2xl font-bold tracking-tight">
        Me trouver<span class="text-accent">.</span>
      </h2>
      <p class="mt-4 leading-relaxed text-muted">
        Sur <a
          href="https://github.com/jeremieflahaut"
          class="font-medium text-fg underline decoration-line underline-offset-4 transition-colors hover:text-accent"
          rel="me">GitHub</a
        > pour le code, ou via le <a
          href="/rss.xml"
          class="font-medium text-fg underline decoration-line underline-offset-4 transition-colors hover:text-accent"
          >flux RSS</a
        > pour suivre les prochains articles.
      </p>
    </section>
  </article>
</BaseLayout>
